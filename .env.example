# Copia este archivo a .env y completa los valores antes de correr en producción
# NUNCA subas el archivo .env a git

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga
DEBUG=False
ALLOWED_HOSTS=villasconcerocio.cl www.villasconcerocio.cl

# Base de datos
DB_NAME=jvweb
DB_USER=jvweb
DB_PASSWORD=pon-una-contrasena-segura-aqui
DB_HOST=postgres        # nombre del Service de K8s
DB_PORT=5432

# Media files
MEDIA_ROOT=/app/media   # mountPath del PVC en K8s

# Email (notificaciones a la junta)
# Para Gmail: genera un App Password en myaccount.google.com/apppasswords
# (requiere tener verificación en 2 pasos activada)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=jjvv.villasconcerocio@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx   # App Password de 16 caracteres
DEFAULT_FROM_EMAIL=JJVV Villas Concepción-El Rocío <jjvv.villasconcerocio@gmail.com>
JUNTA_EMAIL=jjvv.villasconcerocio@gmail.com
SITE_URL=https://villasconcerocio.cl
